@model PostSphere.Models.Comment

@{
    ViewBag.Title = "Responder Comentário";
}

<div class="container mt-5">
    <h3>Responder Comentário</h3>
    @using (Html.BeginForm())
    {
        @Html.HiddenFor(m => m.ParentId)
        @Html.HiddenFor(m => m.TopicId) <!-- Campo oculto para o ID do tópico -->

        <div class="form-group">
            @Html.Label("Autor")
            @Html.TextBoxFor(m => m.Author, new { @class = "form-control", @required = "required" })
        </div>

        <div class="form-group">
            @Html.Label("Comentário")
            @Html.TextAreaFor(m => m.Text, 5, 50, new { @class = "form-control", @required = "required" })
        </div>

        <button type="submit" class="btn btn-success mt-3">Postar Resposta</button>
    }
</div>
