@model List<PostSphere.Models.Comment>

<h2>Lista de Comentários</h2>

<a href="@Url.Action("Create", "Comment")" class="btn btn-primary">Novo Comentário</a>

<table class="table">
    <thead>
        <tr>
            <th>Texto</th>
            <th>Autor</th>
            <th>Data</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var comment in Model)
        {
            <tr>
                <td>@comment.Text</td>
                <td>@comment.Author</td>
                <td>@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <a href="@Url.Action("Details", "Comment", new { id = comment.Id })" class="btn btn-info">Detalhes</a>
                    <a href="@Url.Action("Edit", "Comment", new { id = comment.Id })" class="btn btn-warning">Editar</a>
                    <a href="@Url.Action("Delete", "Comment", new { id = comment.Id })" class="btn btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
